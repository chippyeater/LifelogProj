  "functions_and_apis_touching_db": [
    {
      "name": "backend/api_server.py::create_process_task",
      "api": "POST /api/tasks/process",
      "db_reads": [],
      "db_writes": [
        "init_db",
        "upsert_user(users)",
        "upsert_user_video(user_videos)",
        "set_pipeline_state(user_videos.pipeline_state)"
      ]
    },
    {
      "name": "backend/api_server.py::get_users",
      "api": "GET /api/users",
      "db_reads": [
        "list_users(users)",
        "get_latest_video_record(user_videos)",
        "get_pipeline_state(user_videos.pipeline_state)"
      ],
      "db_writes": [
        "init_db"
      ]
    },
    {
      "name": "backend/api_server.py::get_job_status",
      "api": "GET /api/job-status",
      "db_reads": [
        "get_video_record(user_videos) or get_latest_video_record(user_videos)",
        "get_pipeline_state(user_videos.pipeline_state)"
      ],
      "db_writes": []
    },
    {
      "name": "backend/run_pipeline.py::main",
      "api": null,
      "db_reads": [
        "get_video_record(user_videos)",
        "get_pipeline_state(user_videos.pipeline_state)"
      ],
      "db_writes": [
        "init_db",
        "upsert_user_video(user_videos)",
        "set_pipeline_state(user_videos.pipeline_state)",
        "status='video_uploaded'/'context_extracted'/'all_ready'",
        "processed_at",
        "subevent_count"
      ]
    }
  ],
  "notes": [
    "No MySQL/PostgreSQL/MongoDB client usage was found under backend/.",
    "The only actual relational database access layer is backend/db.py.",
    "user_pipeline is created but not referenced elsewhere in backend/; it appears unused.",
    "pipeline_state is not normalized into a separate table; it is stored as JSON text in user_videos.pipeline_state.",
    "Auxiliary JSON files exist, but they are file-based state, not SQL tables."
  ]

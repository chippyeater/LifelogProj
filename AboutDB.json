{
  "backend_path": "backend/",
  "database_types": [
    {
      "type": "SQLite",
      "engine": "sqlite3",
      "connection": {
        "entrypoints": [
          "backend/db.py::_connect",
          "backend/api_server.py::DB_PATH",
          "backend/run_pipeline.py::main"
        ],
        "database_path_config": "server.database_path",
        "default_database_path": "lifelog.db",
        "connection_code": "sqlite3.connect(db_path)"
      }
    },
    {
      "type": "JSON file store",
      "note": "Used as auxiliary persistence for job status and recall report, not relational tables",
      "stores": [
        {
          "name": "status.json",
          "path_pattern": "backend/output/<user_id>/status.json",
          "read_by": [
            "backend/api_server.py::_read_status_json",
            "backend/api_server.py::_build_job_status_payload",
            "backend/api_server.py::_build_job_status_from_status_doc",
            "backend/api_server.py::_build_user_list_item",
            "backend/api_server.py::get_job_status",
            "backend/run_pipeline.py::_read_status_doc"
          ],
          "write_by": [
            "backend/api_server.py::_write_status_json",
            "backend/api_server.py::create_process_task",
            "backend/run_pipeline.py::_write_status_doc",
            "backend/run_pipeline.py::_update_status_doc",
            "backend/run_pipeline.py::update_status"
          ]
        },
        {
          "name": "recall_report.json",
          "path_pattern": "backend/output/<user_id>/recall_report.json",
          "read_by": [
            "backend/api_server.py::get_recall_report"
          ],
          "write_by": [
            "backend/api_server.py::post_recall_report"
          ]
        }
      ]
    }

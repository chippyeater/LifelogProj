      "initialization": {
        "create_table": "CREATE TABLE IF NOT EXISTS users (...)",
        "default_seed_logic": [
          "backend/db.py::init_db inserts missing users from user_videos",
          "seed status defaults to 'pending' via COALESCE(NULLIF(TRIM(status), ''), 'pending')"

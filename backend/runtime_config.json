    "compression": {
      "enabled_by_default": true,
      "scale_width": -2,
      "scale_height": 720,
      "frame_rate": 8,
      "video_codec": "libx264",
      "video_bitrate": "3M",
      "video_pixel_format": "yuv420p",
      "video_profile": "high",
      "video_level": "4.0",
      "audio_codec": "aac",
      "audio_bitrate": "128k",
      "preset": "",
      "overwrite": true,
      "keep_audio": true,
      "movflags": "+faststart",
      "output_subdir": "compressed",
      "filename_prefix": "compressed"

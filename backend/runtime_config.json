    "media_export": {
      "activity_audio_min_seconds": 3,
      "activity_audio_max_seconds": 8,
      "event_video_min_seconds": 4,
      "event_video_max_seconds": 10,
      "video_codec": "libx264",
      "video_pixel_format": "yuv420p",
      "video_profile": "high",
      "video_level": "4.0",

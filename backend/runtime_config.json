  },
  "pipeline": {
    "default_activity": "shopping",
    "default_people": "me",
    "default_time": "2024-01-05 15:00",
    "default_location": "supermarket",
    "output_root": "output",
    "pipeline_mode": "full_context",
    "start_stage": 1,

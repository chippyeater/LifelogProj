    "embedding": {
      "model_name": "moka-ai/m3e-base",
      "event_similarity_threshold": 0.9,
      "entity_similarity_threshold": 0.9
    }
  },
  "aigc": {
    "max_retry": 3,
    "poll_interval_seconds": 3,
    "timeout_seconds": 30,
    "download_timeout_seconds": 10,
    "prompt_max_chars": 800,
